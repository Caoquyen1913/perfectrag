services:
  notion-sync:
    image: python:3.11-slim
    restart: unless-stopped
    depends_on:
      - qdrant
      - ollama
    environment:
      - NOTION_API_KEY=${NOTION_API_KEY}
      - OLLAMA_URL=http://ollama:11434
      - QDRANT_URL=http://qdrant:6333
      - QDRANT_COLLECTION=${QDRANT_COLLECTION:-documents}
      - EMBEDDING_MODEL={{ recipe.embedding_model if recipe is defined else 'nomic-embed-text' }}
      - SYNC_SCHEDULE=${NOTION_SCHEDULE:-0 */6 * * *}
    working_dir: /app
    command: >
      sh -c "pip install --quiet notion-client qdrant-client httpx croniter pyyaml &&
             python /app/notion_sync.py"
    volumes:
      - ./notion-sync/notion_sync.py:/app/notion_sync.py:ro
      - ./volumes/notion-sync:/app/state
