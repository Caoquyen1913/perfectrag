services:
  ingest-worker:
    build:
      context: ./ingest
      dockerfile: Dockerfile
    restart: unless-stopped
    depends_on:
      - qdrant
      - ollama
    environment:
      - OLLAMA_URL=http://ollama:11434
      - QDRANT_URL=http://qdrant:6333
      - QDRANT_COLLECTION=${QDRANT_COLLECTION:-documents}
      - EMBEDDING_MODEL={{ recipe.embedding_model if recipe is defined else 'nomic-embed-text' }}
      - CHUNK_SIZE={{ recipe.chunk_size if recipe is defined else 512 }}
      - INGEST_CONFIG=/app/config.yml
    volumes:
      - ./ingest/config.yml:/app/config.yml:ro
      - ./volumes/ingest-state:/app/state
