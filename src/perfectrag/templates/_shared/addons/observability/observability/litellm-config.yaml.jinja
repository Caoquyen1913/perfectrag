model_list:
  - model_name: default
    litellm_params:
      model: "ollama/{{ recipe.llm_model if recipe is defined else 'qwen2.5:3b-instruct-q4_K_M' }}"
      api_base: http://ollama:11434

  - model_name: embedding
    litellm_params:
      model: "ollama/{{ recipe.embedding_model if recipe is defined else 'nomic-embed-text' }}"
      api_base: http://ollama:11434

litellm_settings:
  success_callback: ["langfuse"]
  failure_callback: ["langfuse"]
  drop_params: true

general_settings:
  master_key: os.environ/LITELLM_MASTER_KEY
