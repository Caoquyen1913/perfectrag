PROJECT_NAME={{ project_name }}

# Onyx connects to its OWN data sources via connectors (Slack, Drive, GitHub,
# Confluence, ...) configured in the web UI — not via uploaded files.
#
# LLM is configured in the Onyx admin UI. The recipe pick below is a hint:
LLM_HINT={{ recipe.llm_model }}
EMBEDDING_HINT={{ recipe.embedding_model }}
{%- if recipe.llm_runtime in ['gemini', 'anthropic', 'openai'] %}

# Cloud LLM ({{ recipe.llm_runtime }}) — set in Onyx admin UI, or export here:
{{ recipe.llm_runtime | upper }}_API_KEY=
{%- endif %}

POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=onyx
