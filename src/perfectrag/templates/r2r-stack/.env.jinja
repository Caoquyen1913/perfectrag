PROJECT_NAME={{ project_name }}

# Models (R2R routes LLM/embeddings via LiteLLM; local = Ollama)
LLM_MODEL={{ recipe.llm_model }}
EMBEDDING_MODEL={{ recipe.embedding_model }}
{%- if recipe.llm_runtime in ['gemini', 'anthropic', 'openai'] %}

# Cloud LLM ({{ recipe.llm_runtime }}) — fill this in (privacy=hybrid_api was selected)
{{ recipe.llm_runtime | upper }}_API_KEY=
{%- endif %}

# Postgres (R2R's store, with pgvector)
R2R_POSTGRES_USER=postgres
R2R_POSTGRES_PASSWORD=postgres
R2R_POSTGRES_HOST=postgres
R2R_POSTGRES_PORT=5432
R2R_POSTGRES_DBNAME=r2r
# Pin R2R's listen port to match the compose `7272:7272` mapping; the image
# otherwise defaults R2R_PORT=8000, leaving host :7272 with nothing behind it.
R2R_HOST=0.0.0.0
R2R_PORT=7272
# R2R uses this as a Postgres schema name, so it must be a valid SQL identifier.
# The project dir name may contain hyphens (e.g. "r2r-stack") which break the
# CREATE TABLE DDL with `syntax error at or near "-"`, so replace them.
R2R_PROJECT_NAME={{ project_name | replace('-', '_') }}

OLLAMA_API_BASE=http://ollama:11434
