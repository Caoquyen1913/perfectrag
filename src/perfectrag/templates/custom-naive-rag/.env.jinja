PROJECT_NAME={{ project_name }}

# Models
LLM_MODEL={{ recipe.llm_model }}
EMBEDDING_MODEL={{ recipe.embedding_model }}
{%- if recipe.llm_runtime in ['gemini', 'anthropic', 'openai'] %}

# Cloud LLM ({{ recipe.llm_runtime }}) — fill this in (privacy=hybrid_api was selected)
{{ recipe.llm_runtime | upper }}_API_KEY=
{%- endif %}

# Backends
OLLAMA_URL=http://ollama:11434
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=documents

# RAG params
CHUNK_SIZE={{ recipe.chunk_size }}
CHUNK_STRATEGY={{ recipe.chunk_strategy }}
TOP_K=5

# Hardware hints
GPU_ENABLED={{ 'true' if recipe.gpu_enabled else 'false' }}
VRAM_CAP_GB={{ recipe.vram_cap_gb }}
