"""Naive-RAG service backed by perfectrag.core.RAG + mounted /v1/* SaaS API."""

from __future__ import annotations

import os
import uuid
from pathlib import Path

from fastapi import FastAPI, File, HTTPException, UploadFile
from pydantic import BaseModel

from perfectrag import RAG
from perfectrag.query_api import app as saas_app

CONFIG_PATH = os.environ.get("PERFECTRAG_CONFIG", "/app/perfectrag.yml")
os.environ.setdefault("PERFECTRAG_CONFIG", CONFIG_PATH)
os.environ.setdefault("PERFECTRAG_PROJECT_DIR", str(Path(CONFIG_PATH).parent))

app = FastAPI(title="{{ project_name }}", version="1.1.0")

# Legacy endpoints (used by open-webui + existing clients)
_rag: RAG | None = None


def get_rag() -> RAG:
    global _rag
    if _rag is None:
        _rag = RAG.from_config(CONFIG_PATH)
    return _rag


@app.get("/health")
def health() -> dict:
    return {"status": "ok"}


@app.post("/ingest")
async def ingest(file: UploadFile = File(...)) -> dict:
    data_dir = Path("/data")
    data_dir.mkdir(exist_ok=True)
    dst = data_dir / file.filename
    dst.write_bytes(await file.read())
    n = get_rag().ingest(dst)
    return {"chunks": n, "source": file.filename}


class QueryReq(BaseModel):
    question: str
    top_k: int | None = None


@app.post("/query")
def query(req: QueryReq) -> dict:
    result = get_rag().query(req.question, k=req.top_k)
    return result.as_dict()


# OpenAI-compatible chat for open-webui RAG plumbing
class OpenAIChatReq(BaseModel):
    model: str
    messages: list[dict]
    stream: bool = False


@app.post("/v1/chat/completions")
def openai_chat(req: OpenAIChatReq) -> dict:
    last_user = next((m["content"] for m in reversed(req.messages) if m["role"] == "user"), "")
    result = get_rag().query(last_user)
    return {
        "id": str(uuid.uuid4()),
        "object": "chat.completion",
        "model": result.hits[0].chunk.source if result.hits else "rag",
        "choices": [{"index": 0,
                     "message": {"role": "assistant", "content": result.answer},
                     "finish_reason": "stop"}],
    }


# Mount the authenticated SaaS API at /v1 (query, ingest, collections, keys, usage)
app.mount("/", saas_app)
