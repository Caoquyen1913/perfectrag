services:
  qdrant:
    image: qdrant/qdrant:v1.11.0
    restart: unless-stopped
    ports:
      - "6333:6333"
    volumes:
      - ./volumes/qdrant:/qdrant/storage
    healthcheck:
      test: ["CMD", "bash", "-c", "echo > /dev/tcp/localhost/6333"]
      interval: 10s
      retries: 10

  ollama:
    image: ollama/ollama:latest
    restart: unless-stopped
    ports:
      - "11434:11434"
    volumes:
      - ./volumes/ollama:/root/.ollama
{%- if recipe.gpu_enabled and hw.gpu_vendor == 'nvidia' %}
    deploy:
      resources:
        reservations:
          devices:
            - driver: nvidia
              count: all
              capabilities: [gpu]
{%- endif %}

  ollama-pull:
    image: ollama/ollama:latest
    depends_on:
      - ollama
    entrypoint: ["/bin/sh", "-c"]
    command: |
      "sleep 5 && \
       OLLAMA_HOST=ollama:11434 ollama pull {{ recipe.embedding_model if recipe.embedding_model == 'nomic-embed-text' else 'nomic-embed-text' }}{% if recipe.llm_runtime not in ['gemini', 'anthropic', 'openai'] %} && \
       OLLAMA_HOST=ollama:11434 ollama pull {{ recipe.llm_model }}{% endif %}"
    restart: "no"

  app:
    build: ./app
    restart: unless-stopped
    depends_on:
      - qdrant
      - ollama
    env_file: .env
    ports:
      - "8000:8000"
    volumes:
      - ./data:/data
      - ./skills:/app/skills:ro
      - ./perfectrag.yml:/app/perfectrag.yml:ro
      - ./.perfectrag:/app/.perfectrag
    environment:
      - PERFECTRAG_CONFIG=/app/perfectrag.yml
      - PERFECTRAG_PROJECT_DIR=/app
    healthcheck:
      test: ["CMD", "python", "-c", "import urllib.request,sys; sys.exit(0 if urllib.request.urlopen('http://localhost:8000/health').status==200 else 1)"]
      interval: 15s
      retries: 10
      start_period: 30s

  open-webui:
    image: ghcr.io/open-webui/open-webui:main
    restart: unless-stopped
    depends_on:
      - ollama
      - app
    ports:
      - "3000:8080"
    environment:
      - OLLAMA_BASE_URL=http://ollama:11434
      - WEBUI_AUTH=false
      - ENABLE_RAG_WEB_SEARCH=true
      - RAG_OPENAI_API_BASE_URL=http://app:8000/v1
    volumes:
      - ./volumes/open-webui:/app/backend/data
