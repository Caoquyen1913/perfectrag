PROJECT_NAME={{ project_name }}

# LLM (Ollama backend)
LLM_BINDING=ollama
LLM_MODEL={{ recipe.llm_model }}
LLM_BINDING_HOST=http://ollama:11434

# Embedding
EMBEDDING_BINDING=ollama
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_BINDING_HOST=http://ollama:11434
EMBEDDING_DIM=768

# GraphRAG params
CHUNK_SIZE={{ recipe.chunk_size }}
CHUNK_OVERLAP_SIZE=50
MAX_ASYNC=4
MAX_PARALLEL_INSERT=2

# Graph storage (NetworkX by default; switch to Neo4j for scale)
LIGHTRAG_KV_STORAGE=JsonKVStorage
LIGHTRAG_VECTOR_STORAGE=NanoVectorDBStorage
LIGHTRAG_GRAPH_STORAGE=NetworkXStorage
LIGHTRAG_DOC_STATUS_STORAGE=JsonDocStatusStorage

# Hardware hints
GPU_ENABLED={{ 'true' if recipe.gpu_enabled else 'false' }}
VRAM_CAP_GB={{ recipe.vram_cap_gb }}
