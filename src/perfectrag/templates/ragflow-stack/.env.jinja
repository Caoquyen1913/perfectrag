PROJECT_NAME={{ project_name }}

# RAGFlow
DOC_ENGINE=elasticsearch
ES_HOST=elasticsearch
ES_PORT=9200

MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_PASSWORD=infini_rag_flow

REDIS_HOST=redis
REDIS_PORT=6379

MINIO_HOST=minio
MINIO_PORT=9000
MINIO_USER=rag_flow
MINIO_PASSWORD=infini_rag_flow

# LLM wiring (Ollama)
OLLAMA_URL=http://ollama:11434
DEFAULT_LLM={{ recipe.llm_model }}
DEFAULT_EMBEDDING=nomic-embed-text
DEFAULT_RERANKER={{ recipe.reranker or '' }}

# RAG params
CHUNK_SIZE={{ recipe.chunk_size }}
CHUNK_STRATEGY={{ recipe.chunk_strategy }}

# Hardware hints
GPU_ENABLED={{ 'true' if recipe.gpu_enabled else 'false' }}
VRAM_CAP_GB={{ recipe.vram_cap_gb }}
