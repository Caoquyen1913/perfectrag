apiVersion: apps/v1
kind: Deployment
metadata:
  name: qdrant
spec:
  replicas: 1
  selector: { matchLabels: { app: qdrant } }
  template:
    metadata: { labels: { app: qdrant } }
    spec:
      containers:
        - name: qdrant
          image: {{ '{{' }} .Values.image.qdrant {{ '}}' }}
          ports: [{ containerPort: 6333 }]
          volumeMounts:
            - name: data
              mountPath: /qdrant/storage
      volumes:
        - name: data
          persistentVolumeClaim: { claimName: qdrant-data }
---
apiVersion: v1
kind: Service
metadata: { name: qdrant }
spec:
  selector: { app: qdrant }
  ports: [{ port: 6333, targetPort: 6333 }]
---
apiVersion: v1
kind: PersistentVolumeClaim
metadata: { name: qdrant-data }
spec:
  accessModes: [ReadWriteOnce]
  resources:
    requests:
      storage: {{ '{{' }} .Values.persistence.qdrant.size {{ '}}' }}
