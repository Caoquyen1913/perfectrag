app = "{{ project_name if project_name is defined else 'perfectrag' }}"
primary_region = "sin"

[build]
  dockerfile = "app/Dockerfile"

[env]
  OLLAMA_URL = "http://ollama.internal:11434"
  QDRANT_URL = "http://qdrant.internal:6333"
  LLM_MODEL = "{{ recipe.llm_model if recipe is defined else 'qwen2.5:3b-instruct-q4_K_M' }}"
  EMBEDDING_MODEL = "{{ recipe.embedding_model if recipe is defined else 'nomic-embed-text' }}"

[http_service]
  internal_port = 8000
  force_https = true
  auto_stop_machines = true
  auto_start_machines = true
  min_machines_running = 0

[[vm]]
  cpu_kind = "shared"
  cpus = 1
  memory_mb = 1024

# NOTE: Deploy ollama + qdrant as separate apps first:
#   fly launch --copy-config --name perfectrag-ollama --dockerfile ollama.Dockerfile
#   fly launch --copy-config --name perfectrag-qdrant --dockerfile qdrant.Dockerfile
# then `fly deploy` this app.
